{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "mongTang.md",
    "version":  "0.1.0",
    "identifier":  "com.editmd.app",
    "build":  {
                  "beforeDevCommand":  "npm run dev -- --port 5173 --strictPort",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../dist",
                  "devUrl":  "http://localhost:5173"
              },
    "app":  {
                "windows":  [
                                {
                                    "label":  "main",
                                    "title":  "mongTang.md",
                                    "width":  1440,
                                    "height":  900,
                                    "minWidth":  1000,
                                    "minHeight":  640,
                                    "center":  true,
                                    "backgroundColor":  "#0f172a",
                                    "resizable":  true
                                }
                            ]
            },
    "bundle":  {
                   "active":  true,
                   "targets":  [
                                   "nsis"
                               ],
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ]
               }
}
